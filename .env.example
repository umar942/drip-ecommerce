# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Connect → Drivers → Node.js
# Example (replace user, password, cluster):
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# JWT signing secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-secure-random-string

# API server port
PORT=8080

# Shop frontend port (optional, defaults to 3000)
# SHOP_PORT=3000

# Gmail SMTP (use App Password — NOT your normal Gmail password)
# Create at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=umarali40451@gmail.com
SMTP_PASS=your-16-char-gmail-app-password
EMAIL_FROM=DRIP Store <umarali40451@gmail.com>

# Cloudinary (product image uploads)
# Get these from: Cloudinary Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
